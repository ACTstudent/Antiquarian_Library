@model IEnumerable<Antiquarian_Library.Models.Book>

@{
    ViewData["Title"] = "Books Management";
}

<h2 class="page-title">Books Management</h2>

<div class="card">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
        <div style="flex: 1; margin-right: 2rem; position: relative;">
            <i data-feather="search" style="position: absolute; left: 12px; top: 12px; color: var(--accent-tan);"></i>
            <input type="text" class="form-control" placeholder="Search books by title..." style="padding-left: 40px; background-color: var(--bg-main);" />
        </div>
        <a asp-action="Create" class="btn-primary">
            <i data-feather="plus"></i> Add Book
        </a>
    </div>

    <div class="data-table-container">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Author</th>
                    <th>ISBN</th>
                    <th>Category</th>
                    <th>Year</th>
                    <th>Total</th>
                    <th>Available</th>
                    <th>Penalty/Day</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model) {
                    <tr>
                        <td><strong>@item.Title</strong></td>
                        <td>@item.Author</td>
                        <td>@item.ISBN</td>
                        <td>@item.Category</td>
                        <td>@item.Year</td>
                        <td>@item.Total</td>
                        <td>
                            @if (item.Available > 0)
                            {
                                <span style="background-color: var(--success-bg); color: var(--success-text); padding: 4px 8px; border-radius: 12px; font-weight: 500; font-size: 12px;">@item.Available</span>
                            }
                            else
                            {
                                <span style="background-color: var(--error-bg); color: var(--error-text); padding: 4px 8px; border-radius: 12px; font-weight: 500; font-size: 12px;">0</span>
                            }
                        </td>
                        <td>$@item.PenaltyPerDay</td>
                        <td>
                            <div style="display: flex;">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn-icon">
                                    <i data-feather="edit-2" style="width: 16px; height: 16px;"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this book?');">
                                    <button type="submit" class="btn-icon" style="background-color: var(--primary-brown);">
                                        <i data-feather="trash-2" style="width: 16px; height: 16px;"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
