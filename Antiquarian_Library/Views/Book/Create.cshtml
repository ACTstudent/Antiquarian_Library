@model Antiquarian_Library.Models.Book

@{
    ViewData["Title"] = "Add Book";
}

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
    <h2 class="page-title" style="margin: 0;">Add New Book</h2>
    <a asp-action="Index" class="btn-secondary" style="text-decoration: none;">
        <i data-feather="arrow-left" style="width:16px;height:16px;"></i> Back to Books
    </a>
</div>

<div class="card" style="max-width: 100%;">
    <div style="font-weight: 600; color: var(--primary-brown); margin-bottom: 0.5rem; font-size: 18px;">Book Information</div>
    <p style="color: var(--accent-tan); font-size: 14px; margin-bottom: 2rem;">Fill in the details for the new book entry</p>
    <hr style="border: 0; border-top: 1px solid var(--bg-sidebar); margin-bottom: 2rem;" />

    <form asp-action="Create">
        <!-- Row 1: Title & Author -->
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 0.5rem;">
            <div class="form-group">
                <label asp-for="Title" class="form-label" style="color: var(--primary-brown); font-weight: 600;"></label>
                <input asp-for="Title" class="form-control" placeholder="Enter book title" required />
            </div>
            <div class="form-group">
                <label asp-for="Author" class="form-label" style="color: var(--primary-brown); font-weight: 600;"></label>
                <input asp-for="Author" class="form-control" placeholder="Enter author name" required />
            </div>
        </div>

        <!-- Row 2: ISBN & Category -->
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 0.5rem;">
            <div class="form-group">
                <label asp-for="ISBN" class="form-label" style="color: var(--primary-brown); font-weight: 600;"></label>
                <input asp-for="ISBN" class="form-control" placeholder="e.g. 978-0-06-112008-4" required />
            </div>
            <div class="form-group">
                <label asp-for="Category" class="form-label" style="color: var(--primary-brown); font-weight: 600;"></label>
                <input asp-for="Category" class="form-control" placeholder="e.g. Classic Literature" required />
            </div>
        </div>

        <!-- Row 3: Year, Total, Available, Penalty -->
        <div style="display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 1.5rem; margin-bottom: 0.5rem;">
            <div class="form-group">
                <label asp-for="Year" class="form-label" style="color: var(--primary-brown); font-weight: 600;"></label>
                <input asp-for="Year" class="form-control" type="number" placeholder="e.g. 1813" required />
            </div>
            <div class="form-group">
                <label asp-for="Total" class="form-label" style="color: var(--primary-brown); font-weight: 600;"></label>
                <input asp-for="Total" class="form-control" type="number" placeholder="Total copies" required />
            </div>
            <div class="form-group">
                <label asp-for="Available" class="form-label" style="color: var(--primary-brown); font-weight: 600;"></label>
                <input asp-for="Available" class="form-control" type="number" placeholder="Available copies" required />
            </div>
            <div class="form-group">
                <label class="form-label" style="color: var(--primary-brown); font-weight: 600;">Penalty Per Day ($)</label>
                <input asp-for="PenaltyPerDay" class="form-control" type="number" step="0.01" placeholder="e.g. 5.00" required />
            </div>
        </div>

        <hr style="border: 0; border-top: 1px solid var(--bg-sidebar); margin: 2rem 0;" />

        <div style="display: flex; gap: 1rem; justify-content: flex-end;">
            <a asp-action="Index" class="btn-secondary" style="text-decoration: none; display: flex; align-items: center;">
                <i data-feather="x" style="width:16px;height:16px;"></i>&nbsp;Cancel
            </a>
            <button type="submit" class="btn-primary">
                <i data-feather="save" style="width:16px;height:16px;"></i>&nbsp;Save Book
            </button>
        </div>
    </form>
</div>
