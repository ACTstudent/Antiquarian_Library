@model IEnumerable<Antiquarian_Library.Models.BorrowingRequest>

@{
    ViewData["Title"] = "Borrowing Requests";
}

<h2 class="page-title">Borrowing Requests</h2>

<div class="card">
    <div style="font-weight: 500; margin-bottom: 1rem; color: var(--primary-brown);">
        Pending Requests (@Model.Count(r => r.Status == "Pending"))
    </div>
    
    <hr style="border: 0; border-top: 1px solid var(--accent-tan); margin-bottom: 1.5rem; margin-left: -1.5rem; margin-right: -1.5rem;" />

    <div style="margin-bottom: 1.5rem; position: relative;">
        <i data-feather="search" style="position: absolute; left: 12px; top: 12px; color: var(--accent-tan);"></i>
        <input type="text" class="form-control" placeholder="Search by book title, student name, or ID..." style="padding-left: 40px; background-color: var(--bg-main);" />
    </div>

    <div class="data-table-container">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Book Title</th>
                    <th>Student Name</th>
                    <th>Student ID</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Request Date</th>
                    <th>Return Date</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model) {
                    <tr>
                        <td><strong>@item.BookTitle</strong></td>
                        <td>@item.StudentName</td>
                        <td>@item.StudentId</td>
                        <td>@item.Email</td>
                        <td>@item.Phone</td>
                        <td>@item.RequestDate.ToString("yyyy-MM-dd")</td>
                        <td>@item.ReturnDate.ToString("yyyy-MM-dd")</td>
                        <td>
                            @if (item.Status == "Pending")
                            {
                                <form asp-action="Approve" asp-route-id="@item.Id" method="post" style="display:inline;">
                                    <button type="submit" class="btn-primary" style="background-color: var(--success-text); padding: 8px 16px; font-size: 14px; border-radius: 6px;">
                                        <i data-feather="check-circle" style="width: 16px; height: 16px;"></i> Approve
                                    </button>
                                </form>
                            }
                            else
                            {
                                <span style="background-color: var(--success-bg); color: var(--success-text); padding: 6px 12px; border-radius: 6px; font-weight: 600; font-size: 12px;">@item.Status</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
